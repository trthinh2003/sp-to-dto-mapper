<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- NuGet tool config -->
		<PackAsTool>true</PackAsTool>
		<ToolCommandName>sp-dto-gen</ToolCommandName>
		<PackageId>SpDtoGen</PackageId>
		<Version>1.0.0</Version>
		<Authors>thinhschool1357</Authors>
		<Description>Generate C# DTOs from SQL Server Stored Procedures automatically</Description>
		<PackageTags>dotnet-tool;sqlserver;dto;codegen;storedprocedure</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/trthinh2003/sp-to-dto-mapper.git</RepositoryUrl>
	</PropertyGroup>

	<!-- Đính kèm README vào package -->
	<ItemGroup>
  		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.1" />
		<PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
		<PackageReference Include="Spectre.Console" Version="0.49.1" />
	</ItemGroup>
</Project>